---
import { readdirSync } from "node:fs";
import { fileURLToPath } from "node:url";

const pages = readdirSync(fileURLToPath(new URL("../pages", import.meta.url)), {
  recursive: true,
  encoding: "utf8",
})
  .reduce<string[]>((acc, f) => {
    if (!f.endsWith(".astro")) return acc;
    const normalized = f.replace(/\\/g, "/");
    if (normalized.split("/").some((s) => s.startsWith("_"))) return acc;
    const path = `/${normalized.replace(/\.astro$/, "").replace(/\/index$/, "")}`;
    if (path === "/404" || /^\/\d{4}\/\d{2}\/.+/.test(path)) return acc;
    acc.push(path);
    return acc;
  }, [])
  .sort();
---

<!doctype html>
<html lang="ja">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="robots" content="noindex" />
		<title>Dev: Pages Index</title>
	</head>
	<body>
		<ul>
			{pages.map((url) => <li><a href={url}>{url}</a></li>)}
		</ul>
		<style>
			html {
				background: linear-gradient(135deg, #495057 0%, #212529 100%);
				min-height: 100vh;
			}
			body {
				margin: 0;
				font-family: "Courier New", Courier, monospace;
				color: #adb5bd;
				min-height: 100vh;
				display: grid;
				place-items: center;
			}
			ul {
				list-style: none;
				padding: 0;
				margin: 0;
				display: grid;
				gap: 0.125rem;
			}
			li a {
				display: block;
				padding: 0.375rem 0.625rem;
				color: #adb5bd;
				text-decoration: none;
				border-radius: 4px;
				font-size: 0.875rem;
			}
			li a:hover {
				color: #dee2e6;
			}
		</style>
	</body>
</html>
