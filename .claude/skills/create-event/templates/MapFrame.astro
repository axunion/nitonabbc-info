---
type Props = {
  src: string;
  title?: string;
};

const { src, title } = Astro.props;
---

<iframe
  class="iframe"
  src={src}
  title={title || "Google マップ"}
  allowfullscreen=""
  loading="lazy"
  referrerpolicy="no-referrer-when-downgrade"
>
</iframe>

<style>
  .iframe {
    border: 0;
    display: block;
    height: 50vh;
    margin: 1em 0;
    width: 100%;
  }
</style>
